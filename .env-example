# HW2 AI Agent Debate environment template
# Copy this file to .env for local real-provider testing.
# Never commit .env and never paste real keys into README/docs.
#
# Fake mode (--fake, the default) needs NO keys — tests and offline demos
# run with FakeLLMClient + FakeSearchClient only.
#
# Real-provider mode (--no-fake) requires BOTH an LLM key and a search key.
# Real keys belong only in your local .env or environment — never in Git.

# Real search provider: Tavily
SEARCH_API_KEY=
TAVILY_API_KEY=

# Real LLM provider: OpenAI-compatible Chat Completions
OPENAI_API_KEY=
LLM_API_KEY=

# Optional logging level: INFO, DEBUG, WARNING, ERROR
LOG_LEVEL=INFO

# =====================================================================
# HW2 - AI Agent Debate - Environment Variables (example)
# Copy this file to `.env` and fill in your own values.
# Never commit the real `.env` file (already in .gitignore).
# =====================================================================

# --- LLM Provider -----------------------------------------------------
# Pick the provider you want to use. Only one needs to be set.
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# GOOGLE_API_KEY=your-google-key-here

# Optional: override default model for each role
DEBATE_MODEL_PRO=gpt-4o-mini
DEBATE_MODEL_CON=gpt-4o-mini
DEBATE_MODEL_GATEKEEPER=gpt-4o-mini
DEBATE_MODEL_JUDGE=gpt-4o-mini

# --- Debate Settings --------------------------------------------------
# Topic the agents will debate (can also be passed via CLI).
DEBATE_TOPIC=Should AI-generated content require mandatory labeling?

# Maximum number of rounds before the Judge is forced to decide.
DEBATE_MAX_ROUNDS=4

# Maximum tokens per agent reply.
DEBATE_MAX_TOKENS=400

# --- Watchdog ---------------------------------------------------------
# Hard timeout (seconds) for a single agent turn before Watchdog intervenes.
WATCHDOG_TURN_TIMEOUT=30

# Total wall-clock budget (seconds) for the whole debate.
WATCHDOG_TOTAL_TIMEOUT=300

# --- IPC --------------------------------------------------------------
# Transport for inter-agent messaging in later stages.
# One of: memory | queue | pipe
IPC_TRANSPORT=memory

# --- Logging ----------------------------------------------------------
# One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_DIR=logs
TRANSCRIPT_DIR=transcripts

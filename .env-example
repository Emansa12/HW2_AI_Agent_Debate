# =====================================================================
# HW2 - AI Agent Debate - Environment Variables (example)
#
# Copy this file to `.env` and fill in your own values, OR leave it
# alone - the project runs fully offline by default with
# FakeLLMClient + FakeSearchClient and needs zero keys to demo or
# pass tests:
#
#   uv run python -m debate.main --motion "..." --rounds 2 --fake
#
# Stage 11 added optional real-provider modes (`--real-search`,
# `--real-llm`). Those modes read API keys from the environment
# only - they are never embedded in source, config files, or logs.
# Never commit your real `.env` (already in .gitignore).
# =====================================================================

# --- Optional: real LLM provider (Stage 11) ---------------------------
# Used when you pass `--real-llm` (or `--no-fake`). The CLI builds
# a RealLLMClient against an OpenAI-compatible Chat Completions
# endpoint. LLM_API_KEY is the canonical name; OPENAI_API_KEY is
# accepted as an alias so existing OpenAI-style .env files work
# unchanged.
LLM_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- Optional: real search provider (Stage 11) ------------------------
# Used when you pass `--real-search`. The CLI builds a
# RealSearchClient against Tavily (https://api.tavily.com/search).
# SEARCH_API_KEY is the canonical name; TAVILY_API_KEY is accepted
# as a provider-specific alias.
SEARCH_API_KEY=
# TAVILY_API_KEY=

# --- Optional: per-role model overrides -------------------------------
# Reserved for future per-role wiring. Today the same model is used
# for the Judge and both debaters.
# DEBATE_MODEL_PRO=gpt-4o-mini
# DEBATE_MODEL_CON=gpt-4o-mini
# DEBATE_MODEL_JUDGE=gpt-4o-mini

# --- Debate Settings --------------------------------------------------
# Default motion if none is passed via CLI / config.
DEBATE_TOPIC=AI-generated content should require mandatory labeling.

# Max rounds and per-turn token budget. CLI flags `--rounds` and
# config/debate.json take precedence.
DEBATE_MAX_ROUNDS=10
DEBATE_MAX_TOKENS=400

# --- Watchdog ---------------------------------------------------------
WATCHDOG_TURN_TIMEOUT=30
WATCHDOG_TOTAL_TIMEOUT=300

# --- Logging ----------------------------------------------------------
# One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
